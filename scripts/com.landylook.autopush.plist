<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.landylook.autopush</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/landylook/简报网站/scripts/autopush.sh</string>
    </array>

    <!-- 每小时触发一次 -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- 加载时立即运行一次 -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/landylook/简报网站/logs/autopush.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/landylook/简报网站/logs/autopush.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/landylook/简报网站</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/landylook</string>
    </dict>
</dict>
</plist>
